{
  "name": "mercantil-planner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/build-data.mjs",
    "dev": "vite",
    "build:data": "node scripts/build-data.mjs",
    "prebuild": "node scripts/build-data.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "sanity": "tsx scripts/worker-sanity.ts",
    "sanity:views": "tsx scripts/views-sanity.ts",
    "analyze:rf": "tsx scripts/rf-analysis.ts",
    "tbsc:demo": "tsx scripts/run-tbsc.ts",
    "preview:instructivo": "node scripts/build-instructivo-preview.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "pdf:samples": "tsx --tsconfig tsconfig.app.json scripts/generate-pdf-samples.ts",
    "pdf:samples:verify": "tsx --tsconfig tsconfig.app.json scripts/verify-pdf-samples.ts",
    "docs:viewer": "node scripts/build-doc-viewer.mjs",
    "capture:instructivo": "tsx scripts/capture-instructivo.ts",
    "instructivo:build": "node scripts/build-instructivo.mjs",
    "instructivo:build:dist": "node scripts/build-instructivo.mjs --out=dist/instructivo",
    "postbuild": "node scripts/build-instructivo.mjs --out=dist/instructivo"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.6",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "marked": "^18.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
